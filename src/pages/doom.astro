---
// Hidden easter egg — trigger with Konami code: ↑ ↑ ↓ ↓ ← → ← → B A
//
// Requires /public/doom.jsdos — get it from https://dos.zone (search "Doom")
// or build your own: zip DOOM.EXE + DOOM1.WAD + dosbox.conf → rename to .jsdos
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>rip and tear</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://v8.js-dos.com/latest/js-dos.css" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      html, body {
        height: 100%;
        background: #0a0a0a;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: monospace;
        color: #cc0000;
        gap: 0.75rem;
      }

      .label {
        font-size: 0.7rem;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        opacity: 0.4;
      }

      #dos {
        width: min(640px, 100vw);
        aspect-ratio: 4 / 2.5;
        background: #000;
        border: 1px solid rgba(204, 0, 0, 0.15);
      }

      .exit {
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        color: rgba(204, 0, 0, 0.35);
        text-decoration: none;
        transition: color 0.2s;
      }
      .exit:hover { color: rgba(204, 0, 0, 0.7); }
    </style>
  </head>

  <body>
    <span class="label">you weren't supposed to find this</span>
    <div id="dos"></div>
    <a href="/" class="exit">← escape</a>

    <script src="https://v8.js-dos.com/latest/js-dos.js"></script>
    <script>
      Dos(document.getElementById('dos'), {
        url: '/doom.jsdos',
      });
    </script>
  </body>
</html>
